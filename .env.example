# ============================================================
# Short Drama Platform — 环境变量配置
# 复制为 .env 并根据部署环境修改
# ============================================================

# ── 部署模式: single (单机) / distributed (分布式) ──
DEPLOY_MODE=single

# ── 数据库 ──
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=shortdrama
MYSQL_USER=admin
MYSQL_PASSWORD=admin123
MYSQL_ROOT_PASSWORD=password
# 读副本 (分布式模式)
MYSQL_READ_HOST=mysql-read
MYSQL_READ_PORT=3306

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Sentinel 节点 (分布式模式, 逗号分隔)
REDIS_SENTINEL_NODES=

# ── RabbitMQ ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# ── MinIO / S3 ──
STORAGE_TYPE=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=short-drama
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_ENDPOINT=http://minio:9000

# ── Consul 服务发现 ──
CONSUL_HOST=consul
CONSUL_PORT=8500

# ── Elasticsearch ──
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ── API 网关 (Traefik 或 Apache APISIX) ──
API_GATEWAY=apisix
# Traefik: http://localhost:80 (默认)
# APISIX:  http://localhost:9080 (高性能, 18000 QPS)

# ── ClickHouse OLAP 分析数据库 ──
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=
CLICKHOUSE_DB=shortdrama

# ── Kafka 消息队列 (分布式模式) ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# 任务队列后端: memory (开发) / kafka (生产)
TASK_QUEUE_BACKEND=memory

# ── Traefik 网关 ──
TRAEFIK_HOST=traefik

# ── AI 模型 ──
# DeepSeek (剧本/分镜/推荐 — 国内市场首选)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# OpenAI (通用 fallback)
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o
# Anthropic Claude (海外市场首选 — 英文创作最优)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_API_BASE=    # 留空=直连Anthropic SDK; 填URL=走OpenAI兼容代理
# Seedance (图像/视频 — 国内市场)
SEEDANCE_API_KEY=your-seedance-key
SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedream-4-5-251128
SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128
# Google Veo 2 (视频生成 — 海外市场)
VEO_ENABLED=false
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_API_KEY=    # API key fallback (如果不用服务账号)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json

# ── JWT 安全 ──
JWT_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production

# ── 日志 ──
LOG_LEVEL=INFO

# ── 脚本服务 (无状态, 可多实例) ──
SCRIPT_SERVICE_PORT=8000
SCRIPT_SERVICE_REPLICAS=1

# ── 分镜服务 ──
STORYBOARD_SERVICE_PORT=8001
STORYBOARD_SERVICE_REPLICAS=1

# ── AI 图像服务 ──
LLMHUA_SERVICE_PORT=8002
LLMHUA_SERVICE_REPLICAS=1

# ── 推荐服务 ──
RECOMMENDATION_SERVICE_PORT=8004
RECOMMENDATION_SERVICE_REPLICAS=1

# ── 前端 ──
FRONTEND_PORT=3000
FRONTEND_REPLICAS=1
