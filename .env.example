# ============================================================
# Short Drama Platform — 环境变量配置
# 复制为 .env 并根据部署环境修改
# ============================================================

# ── 部署模式: single (单机) / distributed (分布式) ──
DEPLOY_MODE=single

# ── 数据库 ──
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=shortdrama
MYSQL_USER=admin
MYSQL_PASSWORD=admin123
MYSQL_ROOT_PASSWORD=password
# 读副本 (分布式模式)
MYSQL_READ_HOST=mysql-read
MYSQL_READ_PORT=3306

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
# Sentinel 节点 (分布式模式, 逗号分隔)
REDIS_SENTINEL_NODES=

# ── RabbitMQ ──
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USER=admin
RABBITMQ_PASSWORD=admin123
RABBITMQ_VHOST=/

# ── MinIO / S3 ──
STORAGE_TYPE=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=short-drama
STORAGE_REGION=us-east-1
STORAGE_PUBLIC_ENDPOINT=http://minio:9000

# ── Consul 服务发现 ──
CONSUL_HOST=consul
CONSUL_PORT=8500

# ── Elasticsearch ──
ELASTICSEARCH_HOST=elasticsearch
ELASTICSEARCH_PORT=9200

# ── Kafka 消息队列 (分布式模式) ──
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
# 任务队列后端: memory (开发) / kafka (生产)
TASK_QUEUE_BACKEND=memory

# ── Traefik 网关 ──
TRAEFIK_HOST=traefik

# ── AI 模型 ──
# DeepSeek (剧本/分镜/推荐)
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_API_BASE=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Seedance (图像/视频)
SEEDANCE_API_KEY=your-seedance-key
SEEDANCE_API_URL=https://ark.cn-beijing.volces.com/api/v3
SEEDANCE_MODEL=doubao-seedream-4-5-251128
SEEDANCE_VIDEO_MODEL=doubao-seedance-2-0-260128

# ── JWT 安全 ──
JWT_SECRET_KEY=change-me-in-production
SECRET_KEY=change-me-in-production

# ── 日志 ──
LOG_LEVEL=INFO

# ── 脚本服务 (无状态, 可多实例) ──
SCRIPT_SERVICE_PORT=8000
SCRIPT_SERVICE_REPLICAS=1

# ── 分镜服务 ──
STORYBOARD_SERVICE_PORT=8001
STORYBOARD_SERVICE_REPLICAS=1

# ── AI 图像服务 ──
LLMHUA_SERVICE_PORT=8002
LLMHUA_SERVICE_REPLICAS=1

# ── 推荐服务 ──
RECOMMENDATION_SERVICE_PORT=8004
RECOMMENDATION_SERVICE_REPLICAS=1

# ── 前端 ──
FRONTEND_PORT=3000
FRONTEND_REPLICAS=1
