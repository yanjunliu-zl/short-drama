# 应用配置
VITE_APP_NAME="短剧生成平台"
VITE_APP_VERSION=1.0.0
VITE_APP_DESCRIPTION="AI驱动的短剧生成平台"

# API配置
VITE_API_BASE_URL=http://localhost:8080
VITE_API_TIMEOUT=30000

# 功能开关
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_DEBUG=false
VITE_ENABLE_MOCK_API=false

# 第三方服务（示例）
# VITE_GOOGLE_ANALYTICS_ID=
# VITE_SENTRY_DSN=
# VITE_STRIPE_PUBLIC_KEY=
# VITE_ALIPAY_APP_ID=

# 开发配置
VITE_DEV_PROXY_TARGET=http://localhost:8080
VITE_DEV_SERVER_PORT=3000
VITE_DEV_SERVER_HOST=localhost

# 构建配置
VITE_BUILD_SOURCEMAP=true
VITE_BUILD_MINIFY=true
VITE_BUILD_TARGET=es2020

# 安全配置
VITE_CSRF_ENABLED=true
VITE_CSP_ENABLED=true

# 图片上传配置
VITE_MAX_UPLOAD_SIZE=10485760 # 10MB
VITE_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/gif,image/webp

# 视频配置
VITE_MAX_VIDEO_DURATION=300 # 5分钟
VITE_SUPPORTED_VIDEO_FORMATS=mp4,webm,mov