      "options": { "legend": { "calcs": ["mean", "p90"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{ "expr": "histogram_quantile(0.90, sum(rate(http_request_duration_seconds_bucket[2m])) by (le, service))", "legendFormat": "p90 {{service}}", "refId": "A" }, { "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_seconds_bucket[2m])) by (le, service))", "legendFormat": "p50 {{service}}", "refId": "B" }],
      "title": "请求延迟 P50/P90",
