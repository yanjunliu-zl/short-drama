{
  "uid": "shortdrama-ai-usage",
  "title": "Short Drama — AI Usage",
  "tags": ["shortdrama", "ai", "usage"],
  "timezone": "browser",
  "schemaVersion": 39,
  "refresh": "30s",
  "panels": [
    {
      "id": 1,
      "title": "LLM Token 消耗 (24h)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(script_generation_tokens_total[5m]) * 300",
          "legendFormat": "tokens/5min"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "bars", "fillOpacity": 80 }
        }
      }
    },
    {
      "id": 2,
      "title": "LLM 调用次数",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 12, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(script_generation_total{script_type=~\"novel|outline\"}[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }] }, "unit": "short" }
      }
    },
    {
      "id": 3,
      "title": "预估费用 (24h / ¥)",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 16, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(increase(script_generation_cost_estimate_total[24h]))"
        }
      ],
      "fieldConfig": {
        "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": 0 }] }, "unit": "currencyCNY", "decimals": 2 }
      }
    },
    {
      "id": 4,
      "title": "平均生成耗时",
      "type": "stat",
      "gridPos": { "h": 5, "w": 4, "x": 20, "y": 0 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.5, sum(rate(script_generation_duration_seconds_bucket[24h])) by (le))"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": 0 }, { "color": "orange", "value": 300 }] } }
      }
    },
    {
      "id": 5,
      "title": "脚本生成趋势 (12h)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(script_generation_total{status=\"success\"}[5m])) by (script_type)",
          "legendFormat": "{{script_type}} success"
        },
        {
          "refId": "B",
          "expr": "sum(rate(script_generation_total{status=\"failed\"}[5m])) by (script_type)",
          "legendFormat": "{{script_type}} failed"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      }
    },
    {
      "id": 6,
      "title": "生成耗时分布 (P50/P90/P99)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 10 },
      "targets": [
        {
          "refId": "A",
          "expr": "histogram_quantile(0.50, sum(rate(script_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P50"
        },
        {
          "refId": "B",
          "expr": "histogram_quantile(0.90, sum(rate(script_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P90"
        },
        {
          "refId": "C",
          "expr": "histogram_quantile(0.99, sum(rate(script_generation_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      }
    },
    {
      "id": 7,
      "title": "API 请求速率 (按 endpoint)",
      "type": "timeseries",
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(http_requests_total{job=\"script-service\"}[5m])) by (endpoint, status_code)",
          "legendFormat": "{{endpoint}} {{status_code}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" }
        }
      }
    }
  ]
}
